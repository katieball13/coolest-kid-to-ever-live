<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Coolest Kid Ever</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #050505; color: #ffffff; }
        .glass-panel {
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        .hero-text {
            font-size: clamp(3.5rem, 15vw, 11rem);
            line-height: 0.8;
        }
        .accent-glow {
            text-shadow: 0 0 40px rgba(236, 72, 153, 0.4);
        }
        .image-card {
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .image-card:hover {
            transform: scale(1.02) translateY(-10px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
        }
        ::-webkit-scrollbar { width: 0px; }
    </style>
</head>
<body class="antialiased font-sans">

    <nav class="fixed top-0 w-full z-50 p-6 flex justify-between items-center mix-blend-difference">
        <div class="font-black text-2xl tracking-tighter uppercase">CK.26</div>
        <div class="text-[10px] uppercase tracking-[0.4em] font-bold px-4 py-2 border border-white/20 rounded-full bg-black/80">
            Global Status: Verified
        </div>
    </nav>

    <section class="relative h-screen flex flex-col justify-center items-center text-center px-4 overflow-hidden">
        <img src="IMG_0429.jpg" class="absolute inset-0 w-full h-full object-cover opacity-20 grayscale pointer-events-none" alt="Background">
        
        <div class="relative z-10">
            <h1 class="hero-text font-black tracking-tighter uppercase italic accent-glow animate-pulse">
                Welcome
            </h1>
            <div class="mt-8 text-pink-500 font-bold tracking-[0.8em] uppercase text-xs">Witness Greatness</div>
        </div>
    </section>

    <section class="min-h-screen flex flex-col justify-center items-center px-6 py-24 relative bg-[#080808]">
        <div class="absolute top-0 left-0 w-full h-64 bg-gradient-to-b from-[#050505] to-transparent"></div>
        
        <div class="max-w-4xl glass-panel p-10 md:p-24 rounded-[60px] text-center relative z-10">
            <h2 class="text-[10px] uppercase tracking-[0.6em] text-pink-500 font-black mb-10">Legal Recognition</h2>
            <p class="text-3xl md:text-6xl font-bold leading-tight tracking-tighter">
                We are a site to show off the <span class="text-transparent bg-clip-text bg-gradient-to-br from-pink-400 via-purple-500 to-cyan-400">coolest kid to ever live.</span>
            </p>
            <p class="mt-8 text-gray-400 text-lg md:text-2xl font-light italic">
                Officially recognized in 195 countries and 7 continents.
            </p>
            
            <div class="mt-16 pt-16 border-t border-white/5 grid grid-cols-2 gap-12">
                <div>
                    <span class="block text-5xl font-black italic text-white">195</span>
                    <span class="text-[9px] uppercase tracking-[0.3em] text-gray-500 font-bold">Nations Unified</span>
                </div>
                <div>
                    <span class="block text-5xl font-black italic text-white">7/7</span>
                    <span class="text-[9px] uppercase tracking-[0.3em] text-gray-600 font-bold">Continents Swept</span>
                </div>
            </div>
        </div>
    </section>

    <section class="py-32 px-6 max-w-7xl mx-auto">
        <div class="mb-20 flex flex-col md:flex-row justify-between items-end gap-6">
            <div>
                <h2 class="text-xs uppercase tracking-[0.5em] text-cyan-400 font-bold mb-4">The Archives</h2>
                <p class="text-6xl font-black italic tracking-tighter uppercase">Visual Evidence</p>
            </div>
            <p class="text-gray-500 text-sm max-w-xs text-right border-r-2 border-pink-500 pr-4">
                Primary source documentation of undisputed vibes and global influence.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <div class="image-card relative aspect-[3/4] rounded-[40px] overflow-hidden glass-panel border border-white/10 group">
                <img src="IMG_0429.jpg" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" alt="Rockstar">
                <div class="absolute bottom-6 left-6 right-6 p-4 glass-panel rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity">
                    <p class="text-[10px] font-bold uppercase tracking-widest">Exhibit A: Future Rockstar</p>
                </div>
            </div>

            <div class="image-card relative aspect-[3/4] rounded-[40px] overflow-hidden glass-panel border border-white/10 group">
                <img src="IMG_0430.jpg" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" alt="Halloween">
                <div class="absolute bottom-6 left-6 right-6 p-4 glass-panel rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity">
                    <p class="text-[10px] font-bold uppercase tracking-widest">Exhibit B: Cultural Icon</p>
                </div>
            </div>

            <div class="image-card relative aspect-[3/4] rounded-[40px] overflow-hidden glass-panel border border-white/10 group">
                <img src="IMG_0870.jpg" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" alt="Puffer Jacket">
                <div class="absolute bottom-6 left-6 right-6 p-4 glass-panel rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity">
                    <p class="text-[10px] font-bold uppercase tracking-widest">Exhibit C: Winter Heat</p>
                </div>
            </div>

            <div class="md:col-span-2 lg:col-span-3 image-card relative aspect-video rounded-[40px] overflow-hidden glass-panel border border-white/10 group">
                <img src="IMG_1082.jpg" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" alt="Restaurant">
                <div class="absolute bottom-8 left-8 p-6 glass-panel rounded-3xl opacity-0 group-hover:opacity-100 transition-opacity">
                    <p class="text-sm font-black uppercase tracking-[0.3em]">Exhibit D: The Celebration</p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 px-6 max-w-4xl mx-auto text-center border-t border-white/5">
        <p class="text-xl md:text-2xl italic text-gray-500 mb-10">
            *almost cool enough but not as cool
        </p>
        <div class="image-card relative aspect-[3/4] max-w-sm mx-auto rounded-[40px] overflow-hidden glass-panel border border-white/10 group">
            <img src="IMG_9470.jpg" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" alt="Almost Cool Enough">
        </div>
    </section>

    <footer class="py-24 text-center border-t border-white/5 bg-[#030303]">
        <p class="opacity-30 text-[10px] uppercase tracking-[1em] font-bold">
            &copy; 2026 The Coolest Kid Foundation. 100% Certified.
        </p>
    </footer>

</body>
</html>
